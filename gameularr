<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Snake Nasi Padang Legend</title>
    <style>
        body {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            background-color: #1a1a1a;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: white;
            overflow: hidden;
            touch-action: none;
        }

        /* Container Utama */
        #game-wrapper {
            position: relative;
            text-align: center;
        }

        /* Tampilan Skor */
        .stats-container {
            display: flex;
            justify-content: space-around;
            background: #333;
            padding: 10px;
            border-radius: 10px 10px 0 0;
            border: 4px solid #555;
            border-bottom: none;
        }

        /* Layar Game */
        #game-board {
            background-color: #8da300;
            border: 8px solid #555;
            border-radius: 0 0 10px 10px;
            display: block;
            box-shadow: 0 0 20px rgba(0,0,0,0.5);
        }

        /* MENU START (Overlay) */
        #menu-start {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: rgba(0, 0, 0, 0.85);
            width: 80%;
            padding: 20px;
            border-radius: 15px;
            border: 2px solid #8da300;
            z-index: 10;
            text-align: center;
        }

        #menu-start h1 { color: #8da300; margin: 0 0 10px 0; font-size: 24px; }
        #menu-start p { font-size: 14px; margin-bottom: 20px; color: #ccc; }

        .btn-start {
            background: #8da300;
            color: black;
            border: none;
            padding: 15px 30px;
            font-size: 18px;
            font-weight: bold;
            border-radius: 50px;
            cursor: pointer;
            box-shadow: 0 4px 0 #5e6d00;
        }

        .btn-start:active { transform: translateY(2px); box-shadow: 0 2px 0 #5e6d00; }

        /* Kontroler D-Pad */
        .d-pad {
            display: grid;
            grid-template-columns: repeat(3, 70px);
            grid-template-rows: repeat(2, 70px);
            gap: 10px;
            margin-top: 20px;
        }

        .btn-ctrl {
            background: #444;
            color: white;
            border: none;
            border-radius: 15px;
            font-size: 25px;
            display: flex;
            justify-content: center;
            align-items: center;
            box-shadow: 0 4px 0 #222;
        }

        .btn-ctrl:active { background: #666; transform: translateY(2px); }
        .btn-up { grid-column: 2; }
        .btn-left { grid-column: 1; grid-row: 2; }
        .btn-down { grid-column: 2; grid-row: 2; }
        .btn-right { grid-column: 3; grid-row: 2; }
    </style>
</head>
<body>

    <div id="game-wrapper">
        <div class="stats-container">
            <div>Skor: <span id="scoreVal">0</span></div>
            <div>Terbaik: <span id="highScoreVal">0</span></div>
        </div>

        <!-- Canvas Game -->
        <canvas id="game-board" width="300" height="300"></canvas>

        <!-- Menu Start Overlay -->
        <div id="menu-start">
            <h1>SNAKE PADANG</h1>
            <p>Misi: Makan Nasi Padang (🍱) sebanyak mungkin. Jangan tabrak tembok!</p>
            <button class="btn-start" onclick="startGame()">MULAI MAKAN</button>
        </div>
    </div>

    <!-- Kontrol HP -->
    <div class="d-pad">
        <button class="btn-ctrl btn-up" onclick="changeDir('UP')">▲</button>
        <button class="btn-ctrl btn-left" onclick="changeDir('LEFT')">◀</button>
        <button class="btn-ctrl btn-down" onclick="changeDir('DOWN')">▼</button>
        <button class="btn-ctrl btn-right" onclick="changeDir('RIGHT')">▶</button>
    </div>

    <script>
        const canvas = document.getElementById("game-board");
        const ctx = canvas.getContext("2d");
        const menuStart = document.getElementById("menu-start");
        
        const box = 20;
        let score, snake, food, direction, nextDirection, gameLoop;
        let isPlaying = false;

        // Ambil High Score
        let highScore = localStorage.getItem("snakeHighScore") || 0;
        document.getElementById("highScoreVal").innerText = highScore;

        function initGame() {
            score = 0;
            document.getElementById("scoreVal").innerText = score;
            snake = [{x: 8 * box, y: 10 * box}, {x: 7 * box, y: 10 * box}];
            food = { x: 12 * box, y: 10 * box };
            direction = "RIGHT";
            nextDirection = "RIGHT";
        }

        function startGame() {
            initGame();
            menuStart.style.display = "none";
            isPlaying = true;
            // Interval 160ms (Sangat santai dan lambat)
            gameLoop = setInterval(draw, 160);
        }

        function changeDir(newDir) {
            if (newDir === "LEFT" && direction !== "RIGHT") nextDirection = "LEFT";
            if (newDir === "UP" && direction !== "DOWN") nextDirection = "UP";
            if (newDir === "RIGHT" && direction !== "LEFT") nextDirection = "RIGHT";
            if (newDir === "DOWN" && direction !== "UP") nextDirection = "DOWN";
        }

        document.addEventListener("keydown", (e) => {
            if (e.key === "ArrowUp") changeDir("UP");
            if (e.key === "ArrowDown") changeDir("DOWN");
            if (e.key === "ArrowLeft") changeDir("LEFT");
            if (e.key === "ArrowRight") changeDir("RIGHT");
            // Klik enter juga bisa buat start kalau lagi di menu
            if (e.key === "Enter" && !isPlaying) startGame();
        });

        function draw() {
            direction = nextDirection;
            ctx.fillStyle = "#8da300";
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            // Gambar Nasi Padang
            ctx.font = "16px Arial";
            ctx.fillText("🍱", food.x + 2, food.y + 16);

            // Gambar Ular
            snake.forEach((part, index) => {
                const isHead = index === 0;
                ctx.fillStyle = isHead ? "#000" : "#222";
                ctx.beginPath();
                ctx.roundRect(part.x, part.y, box-1, box-1, isHead ? 8 : 4);
                ctx.fill();
                
                if (isHead) {
                    ctx.fillStyle = "white";
                    ctx.fillRect(part.x + 4, part.y + 4, 3, 3);
                    ctx.fillRect(part.x + 12, part.y + 4, 3, 3);
                }
            });

            let headX = snake[0].x;
            let headY = snake[0].y;

            if (direction === "LEFT") headX -= box;
            if (direction === "UP") headY -= box;
            if (direction === "RIGHT") headX += box;
            if (direction === "DOWN") headY += box;

            // Cek Makan
            if (headX === food.x && headY === food.y) {
                score++;
                document.getElementById("scoreVal").innerText = score;
                food = {
                    x: Math.floor(Math.random() * 14 + 1) * box,
                    y: Math.floor(Math.random() * 14 + 1) * box
                };
            } else {
                snake.pop();
            }

            const newHead = { x: headX, y: headY };

            // Game Over
            if (headX < 0 || headX >= canvas.width || headY < 0 || headY >= canvas.height || 
                snake.some((part, i) => i !== 0 && part.x === headX && part.y === headY)) {
                
                clearInterval(gameLoop);
                isPlaying = false;
                
                if (score > highScore) {
                    highScore = score;
                    localStorage.setItem("snakeHighScore", score);
                    document.getElementById("highScoreVal").innerText = highScore;
                }
                
                alert("KENYANG! Skor: " + score);
                menuStart.style.display = "block";
                return;
            }

            snake.unshift(newHead);
        }

        // Gambar tampilan awal sekali
        initGame();
        ctx.fillStyle = "#8da300";
        ctx.fillRect(0, 0, canvas.width, canvas.height);
    </script>
</body>
</html>
